# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interviewiq

# Security
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRE_MINUTES=10080

# University email gate (e.g. @iilm.edu)
ALLOWED_EMAIL_DOMAIN=@iilm.edu

# OTP
OTP_EXPIRE_SECONDS=600

# Dev: expose OTP in API response when DEBUG=true
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bootstrap admin (created on seed if not exists)
BOOTSTRAP_ADMIN_EMAIL=admin@iilm.edu
BOOTSTRAP_ADMIN_PASSWORD=admin123

# ML: set false for faster local dev without downloading models
ML_USE_SENTENCE_TRANSFORMERS=true

# File uploads
UPLOAD_DIR=uploads

# Proctoring
PROCTORING_STORE_SNAPSHOTS=false
INTEGRITY_WEIGHT_DEFAULT=0.15
ANSWER_QUALITY_WEIGHT_DEFAULT=0.85

# SMTP (optional; OTP emailed when set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@iilm.edu
